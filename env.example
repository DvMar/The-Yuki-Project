# ============================================================
# The Yuki Project — runtime environment
# ============================================================

# ---  LLM backend  ------------------------------------------
# Leave LLAMA_CPP_MODEL unset to fall back to HTTP llama-server.
# When set, the in-process llama.cpp backend is used instead.

LLAMA_CPP_MODEL=models/chat/example_model.gguf
# Built from source with CUDA (v0.3.16)

# Embedding model (used in Step 6 — in-process embeddings).
# Set to empty string to keep using sentence-transformers.
LLAMA_CPP_EMBED_MODEL=models/embeddings/nomic-embed-text-v1.5.Q4_K_M.gguf

# Draft model for speculative decoding (leave empty until ready).
LLAMA_CPP_DRAFT_MODEL=

# ---  llama.cpp inference settings  ------------------------
LLAMA_CPP_N_CTX= 16380               #8192 #16384 #32768
LLAMA_CPP_N_GPU_LAYERS=-1
LLAMA_CPP_N_THREADS=8

# ---  llama-server fallback (HTTP backend)  -----------------
LLAMA_SERVER_URL=http://localhost:8080

# ---  Application  ------------------------------------------
SESSION_RESET_ON_STARTUP=false # Set to true to reset the session state on application startup. This can be useful during development or testing to ensure a clean slate each time the application is launched. In practice, you may want to set this to false to preserve session continuity across restarts.
DREAMCYCLE_TEST_MODE=false # Set to true to enable test mode with shorter idle threshold and more verbose logging.
DREAM_IDLE_THRESHOLD_SECONDS=180 # Time in seconds after which the system is considered idle and may trigger certain behaviors (e.g., entering a low-power state, prompting the user, etc.). Adjust as needed for testing or project use.

# Some of the other variables used in codebase:

# LLAMA_CPP_MAX_CONCURRENT=1
# DREAM_SALIENCE_THRESHOLD=0.45
# DREAM_URGENCY_THRESHOLD=0.50

